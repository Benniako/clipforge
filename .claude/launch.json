{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend (FastAPI + pipeline)",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--app-dir", "backend", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend (Vite dev server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    }
  ]
}
